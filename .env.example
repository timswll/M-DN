# Server-Konfiguration für das Uni-Deployment
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# IP-Adresse, auf der der Server lauscht (Standard: 0.0.0.0 = alle Interfaces)
HOST=0.0.0.0

# Port, auf dem der Server läuft (erlaubter Bereich auf dem Uni-Server: 8300-8399)
PORT=8300
